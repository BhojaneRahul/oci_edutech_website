generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  student
}

enum SubjectCategory {
  degree
  puc
}

enum NoteType {
  notes
  model_qp
}

enum DocumentType {
  notes
  model_qp
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?  @db.VarChar(100)
  email        String   @unique @db.VarChar(100)
  password     String?  @db.VarChar(255)
  googleId     String?  @map("google_id") @db.VarChar(255)
  profilePhoto String?  @map("profile_photo") @db.VarChar(255)
  university   String?  @db.VarChar(150)
  phone        String?  @db.VarChar(20)
  course       String?  @db.VarChar(100)
  semester     String?  @db.VarChar(20)
  resetToken   String?  @map("reset_token") @db.VarChar(255)
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  role         UserRole @default(student)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt
  documents    Document[]
  savedDocuments SavedDocument[]
  likedDocuments LikedDocument[]
  notifications Notification[]
  contactInquiries ContactInquiry[] @relation("InquiryToUser")

  @@map("users")
}

model Degree {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String     @default("")
  icon        String     @default("GraduationCap")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subjects    Subject[]
  mockTests   MockTest[]
}

model Subject {
  id         Int             @id @default(autoincrement())
  degreeId   Int?
  category   SubjectCategory @default(degree)
  group      String          @default("")
  name       String
  semester   String          @default("")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  degree     Degree?         @relation(fields: [degreeId], references: [id], onDelete: SetNull)
  notes      Note[]
}

model Note {
  id        Int      @id @default(autoincrement())
  subjectId Int
  title     String
  pdfUrl    String   @db.Text
  type      NoteType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model MockTest {
  id        Int      @id @default(autoincrement())
  title     String
  degreeId  Int
  questions Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  degree    Degree   @relation(fields: [degreeId], references: [id], onDelete: Cascade)
}

model Project {
  id           Int      @id @default(autoincrement())
  title        String
  description  String   @db.Text
  degree       String
  downloadLink String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id         Int          @id @default(autoincrement())
  title      String       @db.VarChar(255)
  subject    String       @db.VarChar(255)
  stream     String       @db.VarChar(50)
  type       DocumentType
  fileUrl    String       @map("file_url") @db.VarChar(255)
  uploadedBy Int          @map("uploaded_by")
  createdAt  DateTime     @default(now()) @map("created_at")
  uploader   User         @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  savedBy    SavedDocument[]
  likedBy    LikedDocument[]

  @@map("documents")
}

model SavedDocument {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  documentId Int      @map("document_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@map("saved_documents")
}

model LikedDocument {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  documentId Int      @map("document_id")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@map("liked_documents")
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  fullName  String   @map("full_name") @db.VarChar(120)
  email     String   @db.VarChar(120)
  category  String   @db.VarChar(80)
  message   String   @db.Text
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation("InquiryToUser", fields: [userId], references: [id], onDelete: SetNull)

  @@map("contact_inquiries")
}

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  title      String   @db.VarChar(255)
  message    String   @db.Text
  documentId Int?     @map("document_id")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
